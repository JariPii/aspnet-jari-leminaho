@{
    var isHome = ViewData["IsHome"] as bool? == true;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CoreFitness</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>

<body class="bg-primary min-h-screen flex flex-col">

    @if(isHome){
        <div class="bg-[url('/images/nav-hero.png')] bg-cover bg-top mx-4 my-1 rounded-3xl">
            @await Html.PartialAsync("Components/Layout/_Navbar")
            @await Html.PartialAsync("Components/Home/_Hero")
        </div>
        @await Html.PartialAsync("Components/Home/_Equipmentbar")
    }
    else
    {
        <div class="bg-[url('/images/nav-hero.png')] bg-cover bg-top m-4 rounded-2xl">
            @await Html.PartialAsync("Components/Layout/_Navbar")
        </div>

    }

    <main role="main" class="flex-1 pb-3">
        <div class='max-w-7xl mx-auto px-6'>
            @RenderBody()
        </div>
    </main>

   @await Html.PartialAsync("Components/Layout/_Footer")

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
