@model ContactUsViewModel

@{
    ViewData["Title"] = "Customer service page";
}

<h1 class='font-header font-medium text-5xl text-center mb-10'>Customer Service</h1>

<cf-section>
    <div class='flex flex-col gap-20'>
        @await Html.PartialAsync("Partials/_ContactUs", Model)
        @await Html.PartialAsync("~/Views/Shared/Components/Shared/_Faq.cshtml", Model.FaqItems)
    </div>
</cf-section>