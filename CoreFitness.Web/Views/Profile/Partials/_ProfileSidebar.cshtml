@model ProfileTabs

<div class='flex flex-col gap-2'>
    <cf-navlink asp-controller="Profile" asp-action="Index" asp-route-tab="@ProfileTabs.About" css-class="@(Model == ProfileTabs.About ? "font-bold" : "")">
        About Me
    </cf-navlink>

    <cf-navlink asp-controller="Profile" asp-action="Index" asp-route-tab="@ProfileTabs.Membership" css-class="@(Model == ProfileTabs.Membership ? "font-bold" : "")">
        My Membership
    </cf-navlink>

    <cf-navlink asp-controller="Profile" asp-action="Index" asp-route-tab="@ProfileTabs.Bookings" css-class="@(Model == ProfileTabs.Bookings ? "font-bold" : "")">
        My Bookings
    </cf-navlink>

    <form asp-controller="Auth" asp-action="SignOut" method="post">
        <button type="submit">Sign Out</button>
    </form>

    <form asp-controller="Profile" asp-action="Delete" method="post">
        <button type="submit" onclick='return confirm("Are tou sure you want to delete your account?")'>Remove Account</button>
    </form>
</div>